X_REPLY_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
X_REPLY_API_KEY="replace-me"
X_REPLY_MODEL="qwen3.5-flash"

# Optional
# X_REPLY_CDP_URL="http://127.0.0.1:9222"
# BROWSER_HARNESS_BIN="./.bin/browser-harness"
# BROWSER_HARNESS_ROOT="./vendor/browser-harness"
# X_REPLY_CHROME_PROFILE_DIR="$HOME/.config/x-reply-bot-chrome"
# X_REPLY_CHROME_PORT="9222"
# X_REPLY_CHROME_BIN="/usr/bin/google-chrome"
# X_REPLY_JITTER_SECONDS="1800"
# X_REPLY_TG_BOT_TOKEN="123456:telegram-bot-token"
# X_REPLY_TG_CHAT_ID="123456789"
# X_REPLY_ENABLE_REPOST="1"  # 转发开关 (0=禁用, 1=启用)
# X_REPLY_ENABLE_QUOTE="1"   # 引用开关 (0=禁用, 1=启用)
# X_REPOST_DAILY_LIMIT="1"   # 每天最多转发次数
# X_POST_SCHEDULE_HOURS="09,13,17,21"  # 主动发帖小时
# X_POST_DAILY_LIMIT="4"               # 每天最多主动发帖次数
# GIPHY_API_KEY="replace-me"        # GIF 搜索 API → https://developers.giphy.com
# UNSPLASH_ACCESS_KEY="replace-me"  # 照片搜索 API → https://unsplash.com/developers
# X_REPLY_IMAGE_API_KEY="sk-..."    # AI 生图 API key
# X_REPLY_IMAGE_API_URL="https://bussiness-api.own-jarvis.com"  # AI 生图 API 地址
# X_REPLY_IMAGE_MODEL="gpt-image-2"   # AI 生图模型
# X_REPLY_IMAGE_COST_CNY="0.070"      # AI 生图单价（元/次）
# Shell-script overrides (read by scripts/_common.sh)
# X_REPLY_PYTHON="python3"
# X_REPLY_SYSTEMD_SERVICE="x-reply-bot.service"
# X_REPLY_SYSTEMD_USER="x-reply-bot"
# X_REPLY_TZ="Asia/Shanghai"

# 热点发现功能
# X_HOTSPOT_ENABLED="1"             # 热点发现开关 (0=禁用, 1=启用)
# X_HOTSPOT_INTERVAL_SECONDS="7200" # 热点发现间隔（秒），默认 2 小时
# X_HOTSPOT_GUARD_SECONDS="600"     # 热点发现保护间隔（秒）
# X_HOTSPOT_DAILY_LIMIT="3"         # 每天最多发几条热点帖
# X_HOTSPOT_SOURCES="hn,producthunt,reddit,lobsters,simonw,github_trending,hf_papers,tldr_ai,openai,anthropic,google"
# X_HOTSPOT_LLM_CANDIDATES="30"     # 每轮送 LLM 评估的未见候选数
